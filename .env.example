# Inference credentials (Nebius Token Factory). Copy to .env and fill in.
NEBIUS_API_KEY=XXX

# MLflow tracking server (started with: uv tool run mlflow server --port 5000).
# The DAG defaults to http://localhost:5000 if unset.
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=evaluate_agent

# --- docker-compose deployment (used for ${VAR} substitution in docker-compose.yaml) ---
# Absolute path to this repo on the host. The Airflow container mounts the repo at this
# SAME path, so the DAG's PROJECT_ROOT matches the host and DockerOperator host-path
# mounts resolve correctly.
HOST_PROJECT_DIR=/home/you/mlops-assignment
# Run the Airflow container as your host user (id -u) so files written to mounted
# volumes (runs/) are owned by you, not root.
AIRFLOW_UID=1000
# Host 'docker' group gid (getent group docker | cut -d: -f3), added to the Airflow
# container so it can use the mounted Docker socket for DockerOperator.
DOCKER_GID=1001
